# Copy this to .env.local and fill in your values

# MongoDB - get free cluster at mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/codepulse

# NextAuth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Redis - get free instance at upstash.com
REDIS_URL=redis://localhost:6379

# Judge0 - get free API key at rapidapi.com/judge0
JUDGE0_API_KEY=your-judge0-api-key
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
