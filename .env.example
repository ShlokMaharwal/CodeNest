# CodeSync Environment Variables

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/codesync?appName=Cluster0

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=<generate-a-random-32-char-string>
NEXTAUTH_URL=http://localhost:3000

# ─── Redis (Upstash for production, or redis://localhost:6379 for local dev) ──
REDIS_URL=redis://localhost:6379

# ─── AI (get free key at aistudio.google.com) ─────────────────────────────────
GEMINI_API_KEY=AIza...

# ─── Invite Tokens ────────────────────────────────────────────────────────────
INVITE_TOKEN_SECRET=<another-random-32-char-string>

# ─── Public URL (used in invite links) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Error Tracking (optional, free tier at sentry.io) ───────────────────────
# SENTRY_DSN=https://...@sentry.io/...
